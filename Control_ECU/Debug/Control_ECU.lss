    19cc:	f0 e0       	ldi	r31, 0x00	; 0
    19ce:	89 81       	ldd	r24, Y+1	; 0x01
    19d0:	80 83       	st	Z, r24

	DDRB=DDRB|(1<<PB3); //set PB3/OC0 as output pin --> pin where the PWM signal is generated from MC.
